---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import NoteLayout from '../../layouts/NoteLayout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', (entry: CollectionEntry<'notes'>) => !entry.data.draft);
  return notes.map((note) => ({
    params: { slug: note.id.replace(/\.mdx?$/, '') },
    props: { note },
  }));
}

const { note } = Astro.props as { note: CollectionEntry<'notes'> };
const { Content } = await render(note);
---

<NoteLayout
  title={note.data.title}
  description={note.data.description}
  publishedAt={note.data.publishedAt}
  updatedAt={note.data.updatedAt}
  tags={note.data.tags}
  kind={note.data.kind}
  rawContent={note.body ?? ''}
>
  <Content />
</NoteLayout>
