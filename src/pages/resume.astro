---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Resume" description="Kyle Daley's professional background — software engineer and cloud architect.">
  <header class="mb-10 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-1">
        Resume
      </h1>
      <p class="text-neutral-600 dark:text-neutral-400 text-sm">
        Software Engineer · Cloud Architect
      </p>
    </div>
    <a
      href="/resume.pdf"
      class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm font-medium bg-brand-600 text-white hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-400 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      PDF
    </a>
  </header>

  <div class="prose prose-neutral dark:prose-invert max-w-none">
    <p class="text-neutral-500 dark:text-neutral-400 text-sm not-prose mb-10">
      Add your resume content here. This is a placeholder.
    </p>

    <h2>Experience</h2>
    <p>Add your experience here.</p>

    <h2>Education</h2>
    <p>Add your education here.</p>

    <h2>Skills</h2>
    <p>Add your skills here.</p>
  </div>
</PageLayout>
