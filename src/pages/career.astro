---
import PageLayout from "../layouts/PageLayout.astro";

interface Role {
  title: string;
  location: string;
  start: string;
  end: string;
  link?: string;
  note?: string;
}

interface Company {
  id: string;
  company: string;
  link?: string;
  footnotes?: string[];
  roles: Role[];
}

interface EducationEntry {
  school: string;
  link?: string;
  credential: string;
  start: string;
  end: string;
}

interface Certification {
  name: string;
  link?: string;
  issuer: string;
  issued: string;
}

const experience: Company[] = [
  {
    id: "morae-gimmal",
    company: "Morae / Gimmal",
    link: "https://morae.com",
    roles: [
      {
        title: "Cloud Architect",
        location: "Remote",
        start: "Feb 2022",
        end: "Present",
        note: "Gimmal was acquired by Morae in May 2025; continued in the same role.",
      },
      {
        title: "Senior Software Engineer",
        location: "Remote",
        start: "Aug 2014",
        end: "Feb 2022",
      },
      {
        title: "Software Engineer",
        location: "Dallas, TX",
        start: "Aug 2011",
        end: "Aug 2014",
      },
    ],
  },
  {
    id: "meisel",
    company: "Meisel",
    footnotes: [
      "Joined part-time as a 1099 contractor in Oct 2007 while still full-time at Hanson, then moved to full-time here before leaving Hanson.",
    ],
    roles: [
      {
        title: "ERP Application Developer",
        location: "Carrollton, TX",
        start: "Oct 2007",
        end: "Aug 2011",
      },
    ],
  },
  {
    id: "hanson",
    company: "Hanson",
    roles: [
      {
        title: "Senior .NET Developer",
        location: "Hybrid",
        start: "Jun 2006",
        end: "Jul 2008",
      },
      {
        title: "Helpdesk Tech II",
        location: "Irving, TX",
        start: "Oct 2003",
        end: "Jun 2006",
        link: "/career/act-i#building-the-help-desk",
      },
    ],
  },
];

const education: EducationEntry[] = [
  {
    school: "The University of Texas at Dallas",
    link: "https://www.utdallas.edu",
    credential: "Bachelor of Science (BS), Management Information Systems, General",
    start: "Aug 1999",
    end: "May 2005",
  },
];

const certifications: Certification[] = [
  {
    name: "CompTIA A+ Certification",
    link: "https://www.comptia.org",
    issuer: "CompTIA",
    issued: "Dec 2000",
  },
];
---

<PageLayout
  title="My Career"
  description="Twenty years of software engineering, and the story behind the résumé."
>
  <header class="mb-10 flex items-start justify-between gap-4">
    <div>
      <h1
        class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-1"
      >
        My Career
      </h1>
      <p class="text-neutral-600 dark:text-neutral-400 text-sm">
        Software Engineer · Cloud Architect
      </p>
    </div>
    <a
      href="/KyleDaleyResume.pdf"
      class="shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm font-medium bg-brand-600 text-white hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-400 transition-colors"
      aria-label="Download PDF résumé"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      PDF
    </a>
  </header>

  <div
    class="prose prose-neutral dark:prose-invert max-w-none prose-a:text-brand-600 dark:prose-a:text-brand-300 mb-10"
  >
    <p>
      My career has taken a path I never could have planned. If you're here
      because of a résumé or LinkedIn, you'll find the highlights,
      technologies, and responsibilities from each stage of my career. Those
      only tell part of the story. The chapters alongside them explain how I
      got there, the people I worked with, the lessons I learned, and the
      moments that quietly changed the direction of my life. If you choose to
      read those, I recommend starting at the beginning.
    </p>

    <p>
      One thread runs through every stage of my career: someone was willing
      to trust me with an opportunity I hadn't quite earned on paper. A
      manager saw potential, a coworker made an introduction, or someone
      simply believed I could grow into a role before I believed it myself. I
      am deeply grateful for each of those people. I worked hard to be worthy
      of the confidence they placed in me, and I hope these stories honor the
      part they played in the engineer I eventually became.
    </p>
  </div>

  <!-- Side-by-side TOCs: résumé (left) vs. chronological chapters (right) -->
  <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
    <nav
      aria-labelledby="resume-toc-heading"
      class="rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 p-5"
    >
      <h2
        id="resume-toc-heading"
        class="text-sm font-semibold uppercase tracking-wide text-neutral-600 dark:text-neutral-400 mb-3"
      >
        By the Résumé
      </h2>
      <ol class="space-y-2 text-sm">
        <li>
          <a href="#professional-experience" class="text-brand-600 dark:text-brand-300 hover:underline">Professional Experience</a>
          <ol class="mt-1.5 ml-3.5 space-y-1.5 border-l border-neutral-200 dark:border-neutral-800 pl-3">
            {experience.map((company) => (
              <li>
                <a href={`#${company.id}`} class="text-neutral-600 dark:text-neutral-400 hover:text-brand-600 dark:hover:text-brand-300 hover:underline">
                  {company.company}
                </a>
              </li>
            ))}
          </ol>
        </li>
        <li><a href="#technical-skills" class="text-brand-600 dark:text-brand-300 hover:underline">Technical Skills</a></li>
        <li><a href="#education" class="text-brand-600 dark:text-brand-300 hover:underline">Education &amp; Certifications</a></li>
      </ol>
    </nav>

    <nav
      aria-labelledby="chapters-toc-heading"
      class="rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 p-5"
    >
      <h2
        id="chapters-toc-heading"
        class="text-sm font-semibold uppercase tracking-wide text-neutral-600 dark:text-neutral-400 mb-3"
      >
        Chronologically
      </h2>
      <ol class="space-y-2 text-sm">
        <li><a href="/career/origins" class="text-brand-600 dark:text-brand-300 hover:underline">Origins: Hall C</a></li>
        <li><a href="/career/act-i" class="text-brand-600 dark:text-brand-300 hover:underline">Act I: An Unexpected Fork</a></li>
        <li><a href="/career/act-ii" class="text-brand-600 dark:text-brand-300 hover:underline">Act II <span class="text-xs italic text-neutral-400 dark:text-neutral-600">(title TBD)</span></a></li>
        <li><a href="/career/act-iii" class="text-brand-600 dark:text-brand-300 hover:underline">Act III <span class="text-xs italic text-neutral-400 dark:text-neutral-600">(title TBD)</span></a></li>
      </ol>
    </nav>
  </div>

  <!-- Pointer to the managers page, linked throughout the chapters -->
  <a
    href="/managers"
    class="not-prose group block rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 p-5 mb-10 hover:border-brand-300 dark:hover:border-brand-700 transition-colors"
  >
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-300 mb-1">
      A running theme
    </p>
    <p class="font-medium text-neutral-900 dark:text-neutral-100 mb-1">
      Managers Who Have Influenced Me
      <span class="text-brand-600 dark:text-brand-300 group-hover:underline">&rarr;</span>
    </p>
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      Almost every chapter below comes back to someone who managed me and
      shaped how I lead and work today. I've collected them in one place.
    </p>
  </a>

  <!-- Résumé sections: content pending -->
  <div
    class="prose prose-neutral dark:prose-invert max-w-none prose-a:text-brand-600 dark:prose-a:text-brand-300"
  >
    <h2 id="professional-experience">Professional Experience</h2>
    <div class="not-prose space-y-6">
      {experience.map((company) => (
        <div id={company.id}>
          <h3 class="text-base font-semibold text-neutral-900 dark:text-neutral-100">
            {company.link ? (
              <a href={company.link} target="_blank" rel="noopener noreferrer" class="hover:underline">
                {company.company}
              </a>
            ) : (
              company.company
            )}
          </h3>
          <ul class="mt-2 space-y-3">
            {company.roles.map((role) => (
              <li>
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-0.5">
                  <span class="text-sm font-medium text-neutral-800 dark:text-neutral-200">
                    {role.link ? (
                      <a href={role.link} class="hover:underline">
                        {role.title}
                      </a>
                    ) : (
                      role.title
                    )}
                  </span>
                  <span class="text-xs text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                    {role.start} &ndash; {role.end}
                  </span>
                </div>
                <p class="text-xs text-neutral-500 dark:text-neutral-400">{role.location}</p>
                {role.note && (
                  <p class="text-xs text-neutral-500 dark:text-neutral-400 italic mt-0.5">
                    {role.note}
                  </p>
                )}
              </li>
            ))}
          </ul>
          {company.footnotes && (
            <ul class="mt-2 space-y-0.5">
              {company.footnotes.map((footnote) => (
                <li class="text-xs text-neutral-500 dark:text-neutral-400 italic">{footnote}</li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>

    <h2 id="technical-skills">Technical Skills</h2>
    <p class="not-prose text-sm text-neutral-500 dark:text-neutral-400 italic">
      Résumé content coming soon.
    </p>

    <h2 id="education">Education &amp; Certifications</h2>
    <div class="not-prose space-y-6">
      <div>
        <h3 class="text-base font-semibold text-neutral-900 dark:text-neutral-100">Education</h3>
        <ul class="mt-2 space-y-3">
          {education.map((entry) => (
            <li>
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-0.5">
                <span class="text-sm font-medium text-neutral-800 dark:text-neutral-200">
                  {entry.link ? (
                    <a href={entry.link} target="_blank" rel="noopener noreferrer" class="hover:underline">
                      {entry.school}
                    </a>
                  ) : (
                    entry.school
                  )}
                </span>
                <span class="text-xs text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                  {entry.start} &ndash; {entry.end}
                </span>
              </div>
              <p class="text-xs text-neutral-500 dark:text-neutral-400">{entry.credential}</p>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-base font-semibold text-neutral-900 dark:text-neutral-100">Certifications</h3>
        <ul class="mt-2 space-y-3">
          {certifications.map((cert) => (
            <li>
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-0.5">
                <span class="text-sm font-medium text-neutral-800 dark:text-neutral-200">
                  {cert.link ? (
                    <a href={cert.link} target="_blank" rel="noopener noreferrer" class="hover:underline">
                      {cert.name}
                    </a>
                  ) : (
                    cert.name
                  )}
                </span>
                <span class="text-xs text-neutral-500 dark:text-neutral-400 whitespace-nowrap">
                  Issued {cert.issued}
                </span>
              </div>
              <p class="text-xs text-neutral-500 dark:text-neutral-400">{cert.issuer}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</PageLayout>
