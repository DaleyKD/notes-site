---
import { ArrowRight } from "lucide-react";

interface Props {
  href: string;
  label: string;
  class?: string;
}

const { href, label, class: className } = Astro.props;
---

<a
  href={href}
  class:list={[
    "inline-flex items-center gap-2 px-7 py-3.5 rounded-lg bg-brand-600 text-white font-semibold text-base hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-400 transition-colors shadow-sm",
    className,
  ]}
>
  {label}
  <ArrowRight size={16} strokeWidth={2.5} />
</a>
