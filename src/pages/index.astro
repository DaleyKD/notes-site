---
import PageLayout from '../layouts/PageLayout.astro';
import PhotoLightbox from '../components/react/PhotoLightbox';
import NoteCard from '../components/astro/NoteCard.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allNotes = await getCollection('notes', (entry: CollectionEntry<'notes'>) => !entry.data.draft);
const notes = allNotes
  .sort((a: CollectionEntry<'notes'>, b: CollectionEntry<'notes'>) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 5);
---

<PageLayout title="Kyle Daley" description="Software engineering, cloud architecture, and the people who made it matter.">
  <section class="pb-16 space-y-10">

    <!-- Intro -->
    <div class="flex items-start gap-5">
      <PhotoLightbox
        src="/daleykd.jpg"
        alt="Kyle Daley"
        imgClass="w-full h-full object-cover rounded-full"
        wrapperClass="w-20 h-20 rounded-full shrink-0 ring-2 ring-neutral-200 dark:ring-neutral-700 overflow-hidden mt-1"
        client:load
      />
      <div class="pl-4 border-l-2 border-brand-600 dark:border-brand-300 space-y-4 text-neutral-700 dark:text-neutral-300 leading-relaxed">
        <p>
          I'm Kyle. I wrote my first programs in high school and somehow turned that into a career that's lasted more than twenty years. I've watched our industry reinvent itself more than once, forgotten more than I realize <em>(but really enjoy when I remember and reminisce!)</em>, love to use semi-colons, and still exclaim with exuberance when a problem that's taken days finally works.
        </p>
        <div class="space-y-2 pt-2">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-300">
            Outside of work
          </p>
          <p>
            In all things, I'm a Christian first; this drives all aspects of my life. My role as a husband and a father of three is more important than anything I could ever do in my career. When I'm not typing feverishly at a keyboard, I enjoy learning about new tech, thinking about guitar gear, volunteering with my kids' <a href="https://americanheritagegirls.org/" target="_blank" rel="noopener noreferrer" class="text-brand-600 dark:text-brand-300 hover:underline">American Heritage Girls</a> and <a href="https://tx0521.org" target="_blank" rel="noopener noreferrer" class="text-brand-600 dark:text-brand-300 hover:underline">Trail Life</a> troops, or <a href="https://www.delykpcb.com" target="_blank" rel="noopener noreferrer" class="text-brand-600 dark:text-brand-300 hover:underline">designing PCBs for guitar effects pedals</a>.
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="flex justify-center">
      <a
        href="/letter"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-lg bg-brand-600 text-white font-semibold text-base hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-400 transition-colors shadow-sm"
      >
        Start Here
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

  </section>

  <!-- Recent notes -->
  <section>
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-300">
        Recent Notes
      </h2>
      <a href="/notes" class="text-sm font-medium text-orange-700 dark:text-orange-400 hover:underline">
        All notes →
      </a>
    </div>
    <div>
      {notes.length === 0 ? (
        <p class="py-8 text-neutral-500 dark:text-neutral-400 text-sm">
          Nothing published yet. Check back soon.
        </p>
      ) : (
        notes.map((note) => (
          <NoteCard
            title={note.data.title}
            description={note.data.description}
            href={`/notes/${note.id.replace(/\.mdx?$/, '')}`}
            publishedAt={note.data.publishedAt}
            kind={note.data.kind}
            tags={note.data.tags}
          />
        ))
      )}
    </div>
  </section>
</PageLayout>
