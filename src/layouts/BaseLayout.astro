---
import '../styles/global.css';
import ScrollToTop from '../components/react/ScrollToTop';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  publishedAt?: Date;
  type?: 'website' | 'article';
}

const {
  title,
  description = 'Software engineering, cloud architecture, faith, and family — a notebook by Kyle Daley.',
  ogImage = '/daleykd.jpg',
  canonicalUrl,
  publishedAt,
  type = 'website',
} = Astro.props;

const siteTitle = title === 'Kyle Daley' ? 'Kyle Daley' : `${title} — Kyle Daley`;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    {publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Kyle Daley" href="/rss.xml" />

    <!-- Dark mode: dark by default; only opt out if user has explicitly chosen light -->
    <script is:inline>
      if (localStorage.getItem('theme') !== 'light') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <slot />
    <ScrollToTop client:load />
  </body>
</html>
