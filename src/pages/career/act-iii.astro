---
import PageLayout from "../../layouts/PageLayout.astro";
import BackLink from "../../components/astro/BackLink.astro";
import ChapterNav from "../../components/astro/ChapterNav.astro";

const prev = { href: "/career/act-ii", label: "Act II: Building an Engineer" };
---

<PageLayout
  title="Act III"
  description="Coming soon — the chapter covering the growth into Cloud Architect and Principal Software Engineer."
>
  <BackLink href="/career">Back to My Career</BackLink>

  <header class="mb-8">
    <p class="text-xs font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-300 mb-1">
      Act III
    </p>
    <h1 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
      <span class="italic text-neutral-400 dark:text-neutral-600">Title TBD</span>
    </h1>
  </header>

  <div
    class="prose prose-neutral dark:prose-invert max-w-none prose-a:text-brand-600 dark:prose-a:text-brand-300 prose-code:font-mono prose-code:before:content-none prose-code:after:content-none"
  >
    <p class="not-prose text-sm text-neutral-500 dark:text-neutral-400 italic">
      Coming soon. Covers the growth into the
      <a href="/career#morae-gimmal">Cloud Architect / Principal Software Engineer</a>
      role I hold today.
    </p>
  </div>

  <ChapterNav prev={prev} />
</PageLayout>
