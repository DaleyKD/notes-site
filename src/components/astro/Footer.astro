---
const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 dark:border-neutral-800 mt-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-neutral-500 dark:text-neutral-400">
    <span>
      © {year} Kyle Daley · Built with{' '}
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Astro</a>,{' '}
      <a href="https://react.dev" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">React</a>,{' '}
      <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Tailwind CSS</a>,
      and a little help from AI
    </span>
    <nav class="flex items-center gap-4 shrink-0">
      <a href="/rss.xml" class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">RSS</a>
      <a href="/sitemap-index.xml" class="hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors">Sitemap</a>
    </nav>
  </div>
</footer>
