---
import { renderEmphasis } from '../../lib/emphasis';

interface Props {
  title: string;
  description: string;
  href: string;
  publishedAt: Date;
  kind: 'note' | 'essay';
  tags?: string[];
}

const { title, description, href, publishedAt, kind, tags = [] } = Astro.props;

const date = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={href} class="group block py-5 border-b border-neutral-200 dark:border-neutral-800 last:border-0">
  <div class="flex items-baseline justify-between gap-4 mb-1.5">
    <h3 class="text-base font-semibold text-neutral-900 dark:text-neutral-100 group-hover:text-brand-600 dark:group-hover:text-brand-300 transition-colors">
      <span set:html={renderEmphasis(title)} />
      {kind === 'essay' && (
        <span class="ml-2 text-xs font-normal px-1.5 py-0.5 rounded bg-orange-50 dark:bg-orange-950 text-orange-700 dark:text-orange-400 align-middle">essay</span>
      )}
    </h3>
    <time
      datetime={publishedAt.toISOString()}
      class="shrink-0 text-xs text-orange-700 dark:text-orange-400"
    >
      {date}
    </time>
  </div>
  <p class="text-sm text-neutral-600 dark:text-neutral-400 line-clamp-2">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-2">
      {tags.slice(0, 3).map((tag) => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-brand-50 dark:bg-brand-950 text-brand-600 dark:text-brand-300 font-medium">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
